# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Optional: model for the agent (default: gpt-4o-mini for cost, use gpt-4o for best quality)
OPENAI_MODEL=gpt-4o-mini

# FlightsAPI (Google Flights data) – get a free key at https://www.flightsapi.io/
FLIGHTSAPI_API_KEY=your-flightsapi-key-here
